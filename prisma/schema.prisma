generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  profile Profile?

  @@map("users")
}

model Profile {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @unique @map("user_id") @db.Uuid
  name               String    @db.VarChar(255)
  timezone           String    @default("UTC") @db.VarChar(50)
  avatarUrl          String?   @map("avatar_url")
  dailyHydrationGoal Int       @default(2000) @map("daily_hydration_goal")
  petName            String    @default("Nix") @map("pet_name") @db.VarChar(100)
  petStatus          String    @default("HAPPY") @map("pet_status") @db.VarChar(50)
  currentXp          Int       @default(0) @map("current_xp")
  streakDays         Int       @default(0) @map("streak_days")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  medications    Medication[]
  medicationLogs MedicationLog[]
  hydrationLogs  HydrationLog[]
  weightLogs     WeightLog[]
  exerciseLogs   ExerciseLog[]

  @@map("profiles")
}

model Medication {
  id         String    @id @default(uuid()) @db.Uuid
  profileId  String    @map("profile_id") @db.Uuid
  name       String    @db.VarChar(255)
  dosage     String    @db.VarChar(100)
  stockCount Int       @default(0) @map("stock_count")
  timeOfDay  String    @map("time_of_day") @db.VarChar(5)
  color      String    @default("#E24A5C") @db.VarChar(7)
  icon       String    @default("pill") @db.VarChar(50)
  frequency  String    @default("DAILY") @db.VarChar(50)
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  profile Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  logs    MedicationLog[]

  @@map("medications")
}

enum MedicationStatus {
  TAKEN
  SKIPPED
  MISSED
}

model MedicationLog {
  id           String           @id @default(uuid()) @db.Uuid
  medicationId String           @map("medication_id") @db.Uuid
  profileId    String           @map("profile_id") @db.Uuid
  status       MedicationStatus
  loggedAt     DateTime         @map("logged_at") @db.Timestamptz
  createdAt    DateTime         @default(now()) @map("created_at")

  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  profile    Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, loggedAt])
  @@map("medication_logs")
}

model HydrationLog {
  id            String   @id @default(uuid()) @db.Uuid
  profileId     String   @map("profile_id") @db.Uuid
  amountMl      Int      @map("amount_ml")
  containerType String   @default("glass") @map("container_type") @db.VarChar(50)
  loggedAt      DateTime @map("logged_at") @db.Timestamptz
  createdAt     DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, loggedAt])
  @@map("hydration_logs")
}

model WeightLog {
  id        String   @id @default(uuid()) @db.Uuid
  profileId String   @map("profile_id") @db.Uuid
  weightKg  Decimal  @map("weight_kg") @db.Decimal(5, 2)
  loggedAt  DateTime @map("logged_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, loggedAt])
  @@map("weight_logs")
}

model ExerciseLog {
  id              String   @id @default(uuid()) @db.Uuid
  profileId       String   @map("profile_id") @db.Uuid
  didExercise     Boolean  @map("did_exercise")
  durationMinutes Int?     @map("duration_minutes")
  loggedAt        DateTime @map("logged_at") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, loggedAt])
  @@map("exercise_logs")
}